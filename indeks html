        stock: 30,
        price: 85000,
        fee: 18000,
        shipping: 18000,
        desc: "Kopi sachet khas Vietnam, praktis untuk stok rumah atau kantor.",
        popular: 68
      }
    ];

    let products = [];
    let cart = [];
    let orders = [];
    let lastInvoice = null;

    document.addEventListener("DOMContentLoaded", initApp);

    function initApp() {
      products = loadJson(STORAGE_KEYS.products, null);
      cart = loadJson(STORAGE_KEYS.cart, []);
      orders = loadJson(STORAGE_KEYS.orders, []);
      lastInvoice = loadJson(STORAGE_KEYS.lastInvoice, null);

      if (!Array.isArray(products) || products.length === 0) {
        products = defaultProducts;
        saveProducts();
      }

      bindEvents();
      renderAll();
      showInvoice(lastInvoice);
    }

    function bindEvents() {
      document.querySelectorAll("#navTabs button").forEach(button => {
        button.addEventListener("click", () => {
          showSection(button.dataset.section);
        });
      });

      document.getElementById("cartNavBtn").addEventListener("click", () => {
        showSection("cartSection");
      });

      document.getElementById("quickSearchBtn").addEventListener("click", () => {
        showSection("catalogSection");
        setTimeout(() => document.getElementById("searchInput").focus(), 50);
      });

      document.getElementById("searchInput").addEventListener("input", renderProducts);
      document.getElementById("categoryFilter").addEventListener("change", renderProducts);
      document.getElementById("sortSelect").addEventListener("change", renderProducts);

      document.getElementById("importFile").addEventListener("change", importDataFromFile);
    }

    function showSection(sectionId) {
      document.querySelectorAll(".section").forEach(section => {
        section.classList.remove("active");
      });

      const target = document.getElementById(sectionId);
      if (target) {
        target.classList.add("active");
      }

      document.querySelectorAll("#navTabs button").forEach(button => {
        button.classList.toggle("active", button.dataset.section === sectionId);
      });

      window.scrollTo({ top: 0, behavior: "smooth" });
      renderAll();
    }

    function renderAll() {
      renderCategoryFilter();
      renderProducts();
      renderCart();
      renderOrders();
      renderAdminProducts();
      renderStats();
      updateCartCount();
    }

    function renderStats() {
      const totalRevenue = orders.reduce((sum, order) => sum + (Number(order.total) || 0), 0);
      document.getElementById("statProducts").textContent = String(products.length);
      document.getElementById("statOrders").textContent = String(orders.length);
      document.getElementById("statRevenue").textContent = rupiah(totalRevenue);
    }

    function renderCategoryFilter() {
      const filter = document.getElementById("categoryFilter");
      const oldValue = filter.value;
      const categories = ["Semua kategori", ...Array.from(new Set(products.map(product => product.category).filter(Boolean))).sort()];
      filter.innerHTML = categories.map(category => {
        const value = category === "Semua kategori" ? "all" : escapeHtml(category);
        return `<option value="${value}">${escapeHtml(category)}</option>`;
      }).join("");
      if (categories.includes(oldValue) || oldValue === "all") {
        filter.value = oldValue;
      }
    }

    function renderProducts() {
      const grid = document.getElementById("productGrid");
      const query = document.getElementById("searchInput").value.trim().toLowerCase();
      const category = document.getElementById("categoryFilter").value;
      const sort = document.getElementById("sortSelect").value;

      let list = products.filter(product => {
        const haystack = [
          product.name,
          product.category,
          product.city,
          product.desc
        ].join(" ").toLowerCase();

        const matchQuery = !query || haystack.includes(query);
        const matchCategory = category === "all" || product.category === category;
        return matchQuery && matchCategory;
      });

      list = sortProducts(list, sort);

      if (list.length === 0) {
        grid.innerHTML = emptyState("🔎", "Produk tidak ditemukan", "Coba ubah kata kunci atau filter kategori.");
        return;
      }

      grid.innerHTML = list.map(product => productCard(product)).join("");
    }

    function sortProducts(list, sort) {
      const copy = [...list];
      if (sort === "priceAsc") {
        copy.sort((a, b) => Number(a.price) - Number(b.price));
      } else if (sort === "priceDesc") {
        copy.sort((a, b) => Number(b.price) - Number(a.price));
      } else if (sort === "feeAsc") {
        copy.sort((a, b) => Number(a.fee) - Number(b.fee));
      } else if (sort === "nameAsc") {
        copy.sort((a, b) => String(a.name).localeCompare(String(b.name)));
      } else {
        copy.sort((a, b) => Number(b.popular || 0) - Number(a.popular || 0));
      }
      return copy;
    }

    function productCard(product) {
      const total = Number(product.price) + Number(product.fee) + Number(product.shipping);
      const stockText = Number(product.stock) > 0 ? `Stok ${product.stock}` : "Habis";
      const disabled = Number(product.stock) <= 0 ? "disabled" : "";
      return `
        <article class="product-card">
          <div class="product-img">
            <div class="product-badge">${escapeHtml(product.city || "Jastip")}</div>
            ${escapeHtml(product.emoji || "📦")}
          </div>
          <div class="product-body">
            <div class="product-title">${escapeHtml(product.name)}</div>
            <div class="product-desc">${escapeHtml(product.desc || "Produk jastip pilihan.")}</div>
            <div class="product-meta">
              <span class="tag">${escapeHtml(product.category || "Umum")}</span>
              <span class="tag">${stockText}</span>
              <span class="tag">Fee ${rupiah(product.fee)}</span>
            </div>
            <div class="price-row">
              <div>
                <div class="price">${rupiah(total)}</div>
                <div class="fee">Barang ${rupiah(product.price)} + fee + ongkir</div>
              </div>
            </div>
            <button class="btn primary block" ${disabled} onclick="addToCart('${product.id}')">
              Tambah ke Keranjang
            </button>
          </div>
        </article>
      `;
    }

    function addToCart(productId) {
      const product = products.find(item => item.id === productId);
      if (!product) {
        toast("Produk tidak ditemukan.");
        return;
      }

      if (Number(product.stock) <= 0) {
        toast("Stok produk habis.");
        return;
      }

      const existing = cart.find(item => item.productId === productId);
      if (existing) {
        if (existing.qty >= Number(product.stock)) {
          toast("Jumlah melebihi stok.");
          return;
        }
        existing.qty += 1;
      } else {
        cart.push({
          productId,
          qty: 1,
          note: ""
        });
      }

      saveCart();
      renderAll();
      toast(`${product.name} masuk keranjang.`);
    }

    function renderCart() {
      const holder = document.getElementById("cartItems");
      const summary = document.getElementById("cartSummary");

      if (!cart.length) {
        holder.innerHTML = emptyState("🛒", "Keranjang masih kosong", "Tambahkan produk dari katalog dulu.");
        summary.innerHTML = cartSummaryHtml();
        return;
      }

      holder.innerHTML = cart.map(item => {
        const product = products.find(product => product.id === item.productId);
        if (!product) return "";
        const subtotal = getItemSubtotal(item, product);
        return `
          <div class="cart-item">
            <div class="cart-icon">${escapeHtml(product.emoji || "📦")}</div>
            <div>
              <div class="cart-name">${escapeHtml(product.name)}</div>
              <div class="cart-note">${escapeHtml(product.category)} · ${escapeHtml(product.city)} · ${rupiah(subtotal)}</div>
            </div>
            <div class="qty">
              <button onclick="decreaseQty('${item.productId}')">−</button>
              <span>${item.qty}</span>
              <button onclick="increaseQty('${item.productId}')">+</button>
              <button onclick="removeFromCart('${item.productId}')" title="Hapus">🗑️</button>
            </div>
          </div>
        `;
      }).join("");

      summary.innerHTML = cartSummaryHtml();
    }

    function cartSummaryHtml() {
      const totals = calculateCartTotals();
      return `
        <div class="summary-row"><span>Subtotal barang</span><strong>${rupiah(totals.goods)}</strong></div>
        <div class="summary-row"><span>Total fee jastip</span><strong>${rupiah(totals.fees)}</strong></div>
        <div class="summary-row"><span>Estimasi ongkir</span><strong>${rupiah(totals.shipping)}</strong></div>
        <div class="summary-row total"><span>Total</span><strong>${rupiah(totals.total)}</strong></div>
        <div style="height:14px"></div>
      `;
    }

    function calculateCartTotals() {
      return cart.reduce((acc, item) => {
        const product = products.find(product => product.id === item.productId);
        if (!product) return acc;

        const qty = Number(item.qty) || 0;
        acc.goods += Number(product.price) * qty;
        acc.fees += Number(product.fee) * qty;
        acc.shipping += Number(product.shipping) * qty;
        acc.total += getItemSubtotal(item, product);
        return acc;
      }, {
        goods: 0,
        fees: 0,
        shipping: 0,
        total: 0
      });
    }

    function getItemSubtotal(item, product) {
      return (Number(product.price) + Number(product.fee) + Number(product.shipping)) * Number(item.qty);
    }

    function increaseQty(productId) {
      const item = cart.find(item => item.productId === productId);
      const product = products.find(product => product.id === productId);
      if (!item || !product) return;

      if (item.qty >= Number(product.stock)) {
        toast("Jumlah sudah sesuai batas stok.");
        return;
      }

      item.qty += 1;
      saveCart();
      renderAll();
    }

    function decreaseQty(productId) {
      const item = cart.find(item => item.productId === productId);
      if (!item) return;

      item.qty -= 1;
      if (item.qty <= 0) {
        cart = cart.filter(item => item.productId !== productId);
      }

      saveCart();
      renderAll();
    }

    function removeFromCart(productId) {
      cart = cart.filter(item => item.productId !== productId);
      saveCart();
      renderAll();
      toast("Produk dihapus dari keranjang.");
    }

    function clearCart() {
      if (!cart.length) {
        toast("Keranjang sudah kosong.");
        return;
      }

      const ok = confirm("Kosongkan keranjang?");
      if (!ok) return;

      cart = [];
      saveCart();
      renderAll();
      toast("Keranjang dikosongkan.");
    }

    function checkout() {
      if (!cart.length) {
        toast("Keranjang masih kosong.");
        return;
      }

      const name = document.getElementById("customerName").value.trim();
      const phone = document.getElementById("customerPhone").value.trim();
      const address = document.getElementById("customerAddress").value.trim();
      const note = document.getElementById("customerNote").value.trim();
      const payment = document.getElementById("paymentMethod").value;

      if (!name || !phone || !address) {
        toast("Isi nama, WhatsApp, dan alamat dulu.");
        return;
      }

      const totals = calculateCartTotals();
      const orderItems = cart.map(item => {
        const product = products.find(product => product.id === item.productId);
        return {
          productId: item.productId,
          name: product ? product.name : "Produk",
          emoji: product ? product.emoji : "📦",
          category: product ? product.category : "Umum",
          city: product ? product.city : "-",
          price: product ? Number(product.price) : 0,
          fee: product ? Number(product.fee) : 0,
          shipping: product ? Number(product.shipping) : 0,
          qty: Number(item.qty),
          subtotal: product ? getItemSubtotal(item, product) : 0
        };
      });

      const order = {
        id: makeId("INV"),
        createdAt: new Date().toISOString(),
        customer: {
          name,
          phone,
          address,
          note,
          payment
        },
        items: orderItems,
        goods: totals.goods,
        fees: totals.fees,
        shipping: totals.shipping,
        total: totals.total,
        status: "pending"
      };

      orders.unshift(order);

      orderItems.forEach(item => {
        const product = products.find(product => product.id === item.productId);
        if (product) {
          product.stock = Math.max(0, Number(product.stock) - Number(item.qty));
        }
      });

      lastInvoice = order;
      cart = [];

      saveOrders();
      saveProducts();
      saveCart();
      saveLastInvoice();

      clearCheckoutForm();
      renderAll();
      showInvoice(order);
      showSection("invoiceSection");
      toast("Pesanan berhasil dibuat.");
    }

    function clearCheckoutForm() {
      document.getElementById("customerName").value = "";
      document.getElementById("customerPhone").value = "";
      document.getElementById("customerAddress").value = "";
      document.getElementById("customerNote").value = "";
      document.getElementById("paymentMethod").value = "Transfer Bank";
    }

    function renderOrders() {
      const holder = document.getElementById("ordersList");

      if (!orders.length) {
        holder.innerHTML = emptyState("📋", "Belum ada order", "Order akan muncul setelah checkout.");
        return;
      }

      holder.innerHTML = orders.map(order => {
        const itemList = order.items.map(item => `${item.qty}x ${escapeHtml(item.name)}`).join(", ");
        return `
          <div class="order-card">
            <div class="order-top">
              <div>
                <div class="order-id">${escapeHtml(order.id)}</div>
                <div class="order-date">${formatDate(order.createdAt)} · ${escapeHtml(order.customer.name)} · ${escapeHtml(order.customer.phone)}</div>
              </div>
              <span class="status ${statusClass(order.status)}">${statusLabel(order.status)}</span>
            </div>
            <div class="invoice-muted">${itemList}</div>
            <div class="summary-row total"><span>Total</span><strong>${rupiah(order.total)}</strong></div>
            <div style="display:flex; gap:8px; flex-wrap:wrap; margin-top:12px;">
              <button class="btn small ghost" onclick="openOrderInvoice('${order.id}')">Lihat invoice</button>
              <button class="btn small secondary" onclick="setOrderStatus('${order.id}', 'process')">Proses</button>
              <button class="btn small accent" onclick="setOrderStatus('${order.id}', 'done')">Selesai</button>
              <button class="btn small danger" onclick="setOrderStatus('${order.id}', 'cancel')">Batal</button>
              <button class="btn small danger" onclick="deleteOrder('${order.id}')">Hapus</button>
            </div>
          </div>
        `;
      }).join("");
    }

    function statusClass(status) {
      if (status === "process") return "process";
      if (status === "done") return "done";
      if (status === "cancel") return "cancel";
      return "pending";
    }

    function statusLabel(status) {
      if (status === "process") return "Diproses";
      if (status === "done") return "Selesai";
      if (status === "cancel") return "Dibatalkan";
      return "Menunggu";
    }

    function setOrderStatus(orderId, status) {
      const order = orders.find(order => order.id === orderId);
      if (!order) return;
      order.status = status;
      saveOrders();
      renderAll();
      toast("Status order diperbarui.");
    }

    function deleteOrder(orderId) {
      const ok = confirm("Hapus order ini?");
      if (!ok) return;
      orders = orders.filter(order => order.id !== orderId);
      if (lastInvoice && lastInvoice.id === orderId) {
        lastInvoice = null;
        saveLastInvoice();
        showInvoice(null);
      }
      saveOrders();
      renderAll();
      toast("Order dihapus.");
    }

    function openOrderInvoice(orderId) {
      const order = orders.find(order => order.id === orderId);
      if (!order) return;
      lastInvoice = order;
      saveLastInvoice();
      showInvoice(order);
      showSection("invoiceSection");
    }

    function showInvoice(order) {
      const target = document.getElementById("invoiceRender");
      if (!order) {
        target.innerHTML = emptyState("🧾", "Belum ada invoice", "Checkout atau pilih order untuk menampilkan invoice.");
        return;
      }

      const rows = order.items.map(item => `
        <tr>
          <td>${escapeHtml(item.name)}</td>
          <td>${item.qty}</td>
          <td>${rupiah(item.price)}</td>
          <td>${rupiah(item.fee)}</td>
          <td>${rupiah(item.shipping)}</td>
          <td>${rupiah(item.subtotal)}</td>
        </tr>
      `).join("");

      target.innerHTML = `
        <div class="invoice-box">
          <div class="invoice-head">
            <div>
              <div class="invoice-brand">Beyazit Cargo</div>
              <div class="invoice-muted">Jastip cepat, aman, dan terpercaya.<br/>Makassar · Indonesia</div>
            </div>
            <div class="invoice-muted">
              <b>Invoice:</b> ${escapeHtml(order.id)}<br/>
              <b>Tanggal:</b> ${formatDate(order.createdAt)}<br/>
              <b>Status:</b> ${statusLabel(order.status)}
            </div>
          </div>

          <div class="two-col">
            <div class="note-box">
              <b>Ditagihkan kepada</b><br/>
              ${escapeHtml(order.customer.name)}<br/>
              ${escapeHtml(order.customer.phone)}<br/>
              ${escapeHtml(order.customer.address)}
            </div>
            <div class="note-box">
              <b>Pembayaran</b><br/>
              ${escapeHtml(order.customer.payment)}<br/>
              Catatan: ${escapeHtml(order.customer.note || "-")}
            </div>
          </div>

          <div style="height:18px"></div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Produk</th>
                  <th>Qty</th>
                  <th>Harga</th>
                  <th>Fee</th>
                  <th>Ongkir</th>
                  <th>Subtotal</th>
                </tr>
              </thead>
              <tbody>${rows}</tbody>
            </table>
          </div>

          <div style="height:16px"></div>
          <div class="summary-row"><span>Subtotal barang</span><strong>${rupiah(order.goods)}</strong></div>
          <div class="summary-row"><span>Total fee jastip</span><strong>${rupiah(order.fees)}</strong></div>
          <div class="summary-row"><span>Estimasi ongkir</span><strong>${rupiah(order.shipping)}</strong></div>
          <div class="invoice-total">${rupiah(order.total)}</div>

          <div style="height:18px"></div>
          <div class="note-box">
            Terima kasih sudah menggunakan layanan Beyazit Cargo. Pesanan akan diproses sesuai jadwal open PO dan ketersediaan barang. Simpan invoice ini sebagai bukti pemesanan.
          </div>
        </div>
      `;
    }

    function copyInvoiceText() {
      if (!lastInvoice) {
        toast("Belum ada invoice untuk disalin.");
        return;
      }

      const lines = [];
      lines.push(`INVOICE ${lastInvoice.id}`);
      lines.push(`Beyazit Cargo`);
      lines.push(`Tanggal: ${formatDate(lastInvoice.createdAt)}`);
      lines.push(`Customer: ${lastInvoice.customer.name}`);
      lines.push(`WhatsApp: ${lastInvoice.customer.phone}`);
      lines.push(`Alamat: ${lastInvoice.customer.address}`);
      lines.push(`Pembayaran: ${lastInvoice.customer.payment}`);
      lines.push("");
      lines.push("Item:");
      lastInvoice.items.forEach(item => {
        lines.push(`- ${item.qty}x ${item.name} = ${rupiah(item.subtotal)}`);
      });
      lines.push("");
      lines.push(`Subtotal barang: ${rupiah(lastInvoice.goods)}`);
      lines.push(`Fee jastip: ${rupiah(lastInvoice.fees)}`);
      lines.push(`Ongkir: ${rupiah(lastInvoice.shipping)}`);
      lines.push(`TOTAL: ${rupiah(lastInvoice.total)}`);
      lines.push("");
      lines.push(`Catatan: ${lastInvoice.customer.note || "-"}`);

      navigator.clipboard.writeText(lines.join("\n"))
        .then(() => toast("Teks invoice disalin."))
        .catch(() => toast("Gagal menyalin invoice."));
    }

    function renderAdminProducts() {
      const tbody = document.getElementById("adminProductsTable");

      if (!products.length) {
        tbody.innerHTML = `<tr><td colspan="6">Belum ada produk.</td></tr>`;
        return;
      }

      tbody.innerHTML = products.map(product => `
        <tr>
          <td>
            <b>${escapeHtml(product.emoji || "📦")} ${escapeHtml(product.name)}</b><br/>
            <span class="invoice-muted">${escapeHtml(product.city || "-")}</span>
          </td>
          <td>${escapeHtml(product.category || "Umum")}</td>
          <td>${rupiah(product.price)}</td>
          <td>${rupiah(product.fee)}</td>
          <td>${Number(product.stock) || 0}</td>
          <td>
            <button class="btn small ghost" onclick="editProduct('${product.id}')">Edit</button>
            <button class="btn small danger" onclick="deleteProduct('${product.id}')">Hapus</button>
          </td>
        </tr>
      `).join("");
    }

    function saveProduct() {
      const id = document.getElementById("editProductId").value;
      const name = document.getElementById("productName").value.trim();
      const emoji = document.getElementById("productEmoji").value.trim() || "📦";
      const category = document.getElementById("productCategory").value.trim() || "Umum";
      const city = document.getElementById("productCity").value.trim() || "Makassar";
      const stock = Number(document.getElementById("productStock").value || 0);
      const price = Number(document.getElementById("productPrice").value || 0);
      const fee = Number(document.getElementById("productFee").value || 0);
      const shipping = Number(document.getElementById("productShipping").value || 0);
      const desc = document.getElementById("productDesc").value.trim();

      if (!name) {
        toast("Nama produk wajib diisi.");
        return;
      }

      if (price <= 0) {
        toast("Harga produk harus lebih dari 0.");
        return;
      }

      const payload = {
        id: id || makeId("PRD"),
        name,
        emoji,
        category,
        city,
        stock,
        price,
        fee,
        shipping,
        desc,
        popular: Math.floor(Math.random() * 50) + 50
      };

      if (id) {
        products = products.map(product => product.id === id ? payload : product);
        toast("Produk diperbarui.");
      } else {
        products.unshift(payload);
        toast("Produk ditambahkan.");
      }

      saveProducts();
      clearProductForm();
      renderAll();
    }

    function editProduct(productId) {
      const product = products.find(product => product.id === productId);
      if (!product) return;

      document.getElementById("productFormTitle").textContent = "Edit produk";
      document.getElementById("editProductId").value = product.id;
      document.getElementById("productName").value = product.name;
      document.getElementById("productEmoji").value = product.emoji;
      document.getElementById("productCategory").value = product.category;
      document.getElementById("productCity").value = product.city;
      document.getElementById("productStock").value = product.stock;
      document.getElementById("productPrice").value = product.price;
      document.getElementById("productFee").value = product.fee;
      document.getElementById("productShipping").value = product.shipping;
      document.getElementById("productDesc").value = product.desc;
      showSection("adminSection");
    }

    function deleteProduct(productId) {
      const product = products.find(product => product.id === productId);
      if (!product) return;
      const ok = confirm(`Hapus produk "${product.name}"?`);
      if (!ok) return;

      products = products.filter(product => product.id !== productId);
      cart = cart.filter(item => item.productId !== productId);
      saveProducts();
      saveCart();
      renderAll();
      toast("Produk dihapus.");
    }

    function cancelEditProduct() {
      clearProductForm();
      toast("Mode edit dibatalkan.");
    }

    function clearProductForm() {
      document.getElementById("productFormTitle").textContent = "Tambah produk";
      document.getElementById("editProductId").value = "";
      document.getElementById("productName").value = "";
      document.getElementById("productEmoji").value = "";
      document.getElementById("productCategory").value = "";
      document.getElementById("productCity").value = "";
      document.getElementById("productStock").value = "";
      document.getElementById("productPrice").value = "";
      document.getElementById("productFee").value = "";
      document.getElementById("productShipping").value = "";
      document.getElementById("productDesc").value = "";
    }

    function seedProducts() {
      const ok = confirm("Reset katalog ke contoh produk? Produk lama akan diganti.");
      if (!ok) return;
      products = defaultProducts.map(product => ({
        ...product,
        id: makeId("PRD")
      }));
      saveProducts();
      renderAll();
      toast("Contoh produk dimuat ulang.");
    }

    function resetAllData() {
      const ok = confirm("Reset semua data? Produk, keranjang, order, dan invoice akan dihapus.");
      if (!ok) return;

      localStorage.removeItem(STORAGE_KEYS.products);
      localStorage.removeItem(STORAGE_KEYS.cart);
      localStorage.removeItem(STORAGE_KEYS.orders);
      localStorage.removeItem(STORAGE_KEYS.lastInvoice);

      products = defaultProducts.map(product => ({
        ...product,
        id: makeId("PRD")
      }));
      cart = [];
      orders = [];
      lastInvoice = null;

      saveProducts();
      saveCart();
      saveOrders();
      saveLastInvoice();
      clearProductForm();
      showInvoice(null);
      renderAll();
      toast("Semua data direset.");
    }

    function exportData() {
      const payload = {
        app: "Beyazit Cargo Single HTML",
        version: "1.0.0",
        exportedAt: new Date().toISOString(),
        products,
        orders,
        cart,
        lastInvoice
      };

      const blob = new Blob([JSON.stringify(payload, null, 2)], {
        type: "application/json"
      });

      const url = URL.createObjectURL(blob);
      const anchor = document.createElement("a");
      anchor.href = url;
      anchor.download = `beyazit-cargo-data-${Date.now()}.json`;
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      URL.revokeObjectURL(url);
      toast("Data diexport.");
    }

    function importDataFromFile(event) {
      const file = event.target.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = () => {
        try {
          const payload = JSON.parse(reader.result);
          if (Array.isArray(payload.products)) products = payload.products;
          if (Array.isArray(payload.orders)) orders = payload.orders;
          if (Array.isArray(payload.cart)) cart = payload.cart;
          if (payload.lastInvoice) lastInvoice = payload.lastInvoice;

          saveProducts();
          saveOrders();
          saveCart();
          saveLastInvoice();
          renderAll();
          showInvoice(lastInvoice);
          toast("Data berhasil diimport.");
        } catch (error) {
          toast("File JSON tidak valid.");
        } finally {
          event.target.value = "";
        }
      };
      reader.readAsText(file);
    }

    function updateCartCount() {
      const count = cart.reduce((sum, item) => sum + Number(item.qty || 0), 0);
      document.getElementById("cartCount").textContent = String(count);
    }

    function saveProducts() {
      localStorage.setItem(STORAGE_KEYS.products, JSON.stringify(products));
    }

    function saveCart() {
      localStorage.setItem(STORAGE_KEYS.cart, JSON.stringify(cart));
    }

    function saveOrders() {
      localStorage.setItem(STORAGE_KEYS.orders, JSON.stringify(orders));
    }

    function saveLastInvoice() {
      localStorage.setItem(STORAGE_KEYS.lastInvoice, JSON.stringify(lastInvoice));
    }

    function loadJson(key, fallback) {
      try {
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : fallback;
      } catch (error) {
        return fallback;
      }
    }

    function makeId(prefix) {
      const random = Math.random().toString(36).slice(2, 8).toUpperCase();
      const time = Date.now().toString(36).slice(-5).toUpperCase();
      return `${prefix}-${time}-${random}`;
    }

    function rupiah(value) {
      return new Intl.NumberFormat("id-ID", {
        style: "currency",
        currency: "IDR",
        maximumFractionDigits: 0
      }).format(Number(value || 0));
    }

    function formatDate(value) {
      try {
        return new Intl.DateTimeFormat("id-ID", {
          dateStyle: "medium",
          timeStyle: "short"
        }).format(new Date(value));
      } catch (error) {
        return "-";
      }
    }

    function escapeHtml(value) {
      return String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function emptyState(icon, title, text) {
      return `
        <div class="empty-state">
          <div class="emoji">${icon}</div>
          <b>${escapeHtml(title)}</b>
          <p>${escapeHtml(text)}</p>
        </div>
      `;
    }

    function toast(message) {
      const toastEl = document.getElementById("toast");
      toastEl.textContent = message;
      toastEl.classList.add("show");
      clearTimeout(window.__toastTimer);
      window.__toastTimer = setTimeout(() => {
        toastEl.classList.remove("show");
      }, 2500);
    }

    window.showSection = showSection;
    window.addToCart = addToCart;
    window.increaseQty = increaseQty;
    window.decreaseQty = decreaseQty;
    window.removeFromCart = removeFromCart;
    window.clearCart = clearCart;
    window.checkout = checkout;
    window.setOrderStatus = setOrderStatus;
    window.deleteOrder = deleteOrder;
    window.openOrderInvoice = openOrderInvoice;
    window.copyInvoiceText = copyInvoiceText;
    window.saveProduct = saveProduct;
    window.editProduct = editProduct;
    window.deleteProduct = deleteProduct;
    window.cancelEditProduct = cancelEditProduct;
    window.seedProducts = seedProducts;
    window.resetAllData = resetAllData;
    window.exportData = exportData;
  </script>
